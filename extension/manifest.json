{
  "manifest_version": 3,
  "name": "RedditVault Sync",
  "version": "1.0.0",
  "description": "Syncs your Reddit saved items to RedditVault via your logged-in session",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RedditVault Sync",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
